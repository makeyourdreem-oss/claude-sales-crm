# ==========================================
#  Telegram Bot → CRM — example .env
#  Скопируй как .env и заполни
# ==========================================

# --- Telegram ---
TELEGRAM_BOT_TOKEN=""
ALLOWED_USER_IDS="123456789"  # comma-separated, твой Telegram user ID (узнать у @userinfobot)

# --- Gemini ---
GEMINI_API_KEY=""
GEMINI_MODEL="gemini-2.0-flash-exp"

# --- Google Sheets ---
GOOGLE_SERVICE_ACCOUNT_PATH="/app/secrets/service-account.json"
CRM_SHEET_ID=""

# --- Контекст для классификации (используется в prompt'ах Gemini) ---
PRODUCT_DESCRIPTION="Что ты продаёшь — короткое описание"
ICP_DESCRIPTION="Кто твой ICP"
LANGUAGE="ru"  # для транскрипции и summary

# --- Logging ---
LOG_LEVEL="INFO"  # DEBUG|INFO|WARNING|ERROR

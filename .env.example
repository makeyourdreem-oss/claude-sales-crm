# ============================================================
#  Claude Sales CRM Toolkit — example .env
#  Скопируй как .env и заполни. .env в .gitignore — НЕ коммить.
# ============================================================

# --- Personal context (используется для генерации сообщений) ---
PRODUCT_DESCRIPTION="Симуляторы / тренажёры / digital twin для X"
ICP_DESCRIPTION="B2B компании в отрасли Y, размер 50-500 сотрудников"
AVERAGE_DEAL_SIZE="500000-3000000 RUB"
MESSAGE_STYLE="direct"   # direct|warm|formal

# --- CRM backend ---
CRM_BACKEND="google_sheets"   # google_sheets|notion|csv
CRM_SHEET_ID="<your-google-sheet-id>"
GOOGLE_SERVICE_ACCOUNT_PATH="/absolute/path/to/service-account.json"

# --- Telegram (для /sync-messenger) ---
TG_API_ID=""
TG_API_HASH=""
TG_SESSION=""

# --- Web search cascade (priority order, comma-separated) ---
WEB_SEARCH_CASCADE="exa,apify,websearch"
EXA_API_KEY=""
APIFY_TOKEN=""
SERPER_API_KEY=""

# --- Daily digest ---
DIGEST_TIMEZONE="Europe/Moscow"
DIGEST_RED_ZONE_DAYS=14
DIGEST_KP_GRACE_DAYS=5
DIGEST_GENERATE_DRAFTS=true

# --- Meeting notes ---
MEETINGS_INBOX="./meetings/inbox"
MEETINGS_DONE="./meetings/done"
MEETING_NOTES_STYLE="default"
